<h2 class="ui center aligned header">Welcome to MessageMe - a complete Chat App</h2>
<h4 class="ui center aligned icon header">
  <i class="circular orange power off icon"></i>
  Login to continue</h4>
<div class="ui placeholder segment">
  <div class="ui two column very relaxed stackable grid">
    <div class="column">
      <div class="ui form">
        <%= form_for(:session, html: {class:"ui form", role: 'form'}, url: login_path) do |form| %>
          <div class="field">
            <%= form.label :username %>
            <div class="ui left icon input">
              <%= form.text_field :username, placeholder: "Username" %>
              <i class="user icon"></i>
            </div>
          </div>
          <div class="field">
            <%= form.label :password %>
            <div class="ui left icon input">
              <%= form.password_field :password ,placeholder: "Password" %>
              <i class="lock icon"></i>
            </div>
          </div>
          <%= form.button "Login",  class:"ui fluid orange submit button" %>
        <% end %>
      </div>
    </div>
    <div class="middle aligned column">
      <div class="ui orange big button">
        <i class="signup icon"></i>
        Sign Up
      </div>
    </div>
  </div>
  <div class="ui vertical divider">
    Or
  </div>
</div>
